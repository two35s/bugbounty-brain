  "summaries": [
    {
      "id": 1213,
      "category": "team",
      "content": "Due to a misconfiguration, the 'authorize' button on the OAuth authorization page was vulnerable to clickjacking.\n\nThe bug was fixed by ensuring our OAuth-related responses included the same security headers (including X-Frame-Options) as the rest of the site.\n",
