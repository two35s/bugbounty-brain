  "summaries": [
    {
      "id": 2824,
      "category": "team",
      "content": "When applying for monthly billing, statistics and data regarding account usage that was fetched and subsequently submitted could be tampered with. This data would be reviewed by a human making a credit decision, potentially influencing their decision inappropriately in favor of the applicant.",
      "updated_at": "2016-10-20T20:02:57.042Z",
      "can_view?": true,
      "can_create?": false,
      "attachments": [],
      "user": {
