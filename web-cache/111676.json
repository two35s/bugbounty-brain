  "summaries": [
    {
      "id": 1325,
      "category": "team",
      "content": "Fabricating a large HackerOne url resulted in a 502 response from CloudFlare as the initial header was too large to process for our load balancer proxied by CloudFlare. If the user requesting the url was signed in it would result in a broken reports page. But if the user was signed out this would result in a CloudFlare page stating \"This website is offline\" which would persist until a browser restart or cookie removal.\n\nIncreasing the load balancer proxy buffer size mitigated the issue.",
      "updated_at": "2016-02-10T14:10:23.970Z",
      "can_view?": true,
      "can_create?": false,
