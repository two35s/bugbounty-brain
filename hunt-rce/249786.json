    {
      "id": 4808,
      "category": "researcher",
      "content": "\u042e\u0440\u0430 \u043f\u0440\u0435\u0434\u043f\u043e\u043b\u043e\u0436\u0438\u043b , \u0447\u0442\u043e \u0432 \u0418\u0441\u0442\u043e\u0440\u0438\u044f\u0445 \u043d\u0435\u0442\u0443 \u0444\u043b\u0443\u0434 \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u044f . \u041f\u044b\u0442\u0430\u043b\u0441\u044f \u0434\u043e\u0431\u044b\u0442\u044c \u0437\u0430\u043f\u0440\u043e\u0441 , \u043d\u043e \u0431\u0435\u0437 \u0443\u0441\u043f\u0435\u0448\u043d\u043e .\n\u041e\u0431\u0440\u0430\u0442\u0438\u0432\u0448\u0438\u0441\u044c \u043a\u043e \u043c\u043d\u0435 \u044f \u0435\u043c\u0443 \u043f\u043e\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u043b \u043d\u0430\u043b\u0438\u0447\u0438\u0435 \u0443\u044f\u0437\u0432\u0438\u043c\u043e\u0441\u0442\u0438 \u0432\u043e \u0444\u043b\u0443\u0434\u0435 \u0438\u0441\u0442\u043e\u0440\u0438\u044f\u043c\u0438 , \u0434\u0430\u043b\u044c\u043d\u0435\u0439\u0448\u0435\u043c \u043e\u043d \u0434\u0430\u043b \u0438\u0434\u0435\u044e \u043f\u0440\u043e\u0432\u0435\u0440\u0438\u0442\u044c \u043e\u0442\u043f\u0440\u0430\u0432\u043a\u0443 \u0432 \u043b\u0438\u0447\u043d\u044b\u0435 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u044f \u0438\u0441\u0442\u043e\u0440\u0438\u0439 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u0438\u043c \u0434\u0440\u0443\u0437\u044c\u044f\u043c , \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u043f\u043e\u043a\u0430\u0437\u0430\u043b\u0430 , \u0447\u0442\u043e \u0442\u0430\u043a \u0436\u0435 \u0432\u0441\u0435 \u0440\u0430\u0431\u043e\u0442\u0430\u043b\u043e. \n\u041c\u044b \u0440\u0430\u0437\u0434\u0438\u043b\u0438 \u044d\u0442\u0443 \u0449\u0435\u0434\u0440\u0443\u044e \u043d\u0430\u0433\u0440\u0430\u0434\u0443 50/50 \u043f\u043e \u0431\u0440\u0430\u0442\u0441\u043a\u0438 ! \u041f\u043e\u043f\u044c\u0435\u043c \u043f\u0438\u0432\u043a\u043e \u0432\u0435\u0447\u0435\u0440\u043e\u043c .\n\n\u042f \u0441\u043e\u0441\u0442\u0430\u0432\u0438\u043b \u043e\u0442\u0447\u0435\u0442 \u0438 \u043e\u0442\u043f\u0440\u0430\u0432\u0438\u043b \u0441\u043e \u0441\u0432\u043e\u0435\u0433\u043e \u0430\u043a\u043a\u0430\u0443\u043d\u0442\u0430 @pisarenko \u0441 \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u044f \u042e\u0440\u0438\u044f  , \u0442\u0430\u043a \u043a\u0430\u043a \u043e\u0442\u0447\u0435\u0442 \u0442\u0440\u0435\u0431\u043e\u0432\u0430\u043b POC , \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0440\u0430\u0431\u043e\u0442\u0430\u043b \u043d\u0430 \u043c\u043e\u0435\u043c \u0430\u043a\u043a\u0430\u0443\u043d\u0442\u0435 , \u0430 \u0441\u043e \u0441\u0432\u043e\u0435\u0433\u043e \u043e\u043d \u043d\u0435 \u043c\u043e\u0433 \u043f\u043e\u0432\u0442\u043e\u0440\u0438\u0442\u044c \u0432 \u0441\u0432\u044f\u0437\u0438 \u043e\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u044f \u0437\u0430\u043f\u0440\u043e\u0441\u0430 \u0432 \u0441\u0432\u043e\u0438\u0445 \u043b\u043e\u0433\u0430\u0445.\n\n\n\n\u0412 \u0432\u043a\u043e\u043d\u0442\u0430\u043a\u0442\u0435 \u043d\u0435 \u0431\u044b\u043b\u043e \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u0439 \u043d\u0430 \u043e\u0442\u043f\u0440\u0430\u0432\u043a\u0443 \u0418\u0421\u0422\u041e\u0420\u0418\u0419  \u0432 \u043b\u0438\u0447\u043d\u044b\u0435 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u044f \u0434\u0440\u0443\u0437\u044c\u044f\u043c . \n\u0422\u0435\u043c \u0441\u0430\u043c\u044b\u043c \u043c\u044b \u043c\u043e\u0433\u043b\u0438  \u0437\u0430\u0444\u043b\u0443\u0434\u0438\u0442\u044c \u043b\u0438\u0447\u043d\u044b\u0435 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u044f \u0434\u0440\u0443\u0437\u0435\u0439 (\u0435\u0441\u043b\u0438 \u0443 \u0432\u0430\u0441 9999 \u0434\u0440\u0443\u0437\u0435\u0439 \u043e\u0434\u043d\u0438\u043c \u0437\u0430\u043f\u0440\u043e\u0441\u043e\u043c \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u043b\u043e\u0441\u044c \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u0435 \u0432\u0441\u0435\u043c 9999 \u0434\u0440\u0443\u0437\u044c\u044f\u043c \u0432 \u043e\u0431\u0449\u0435\u0439 \u0441\u043b\u043e\u0436\u043d\u043e\u0441\u0442\u0438 9999 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u0439) \n\n\u0415\u0441\u043b\u0438 \u043f\u043e\u0432\u0442\u043e\u0440\u044f\u0442\u044c \u0437\u0430\u043f\u0440\u043e\u0441 1000 \u0440\u0430\u0437 \u0432 \u0441\u0443\u043c\u043c\u0435 \u0431\u044b\u043b\u043e \u0431\u044b 9999000 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u0439 \u0440\u0430\u0437\u043e\u0441\u043b\u0430\u043d\u043e \u0437\u0430 \u043c\u0438\u043d\u0443\u0442\u0443 \u0441 \u043d\u0435\u0431\u043e\u043b\u044c\u0448\u0438\u043c .\n\n\u0421\u043f\u0430\u0441\u0438\u0431\u043e \u042e\u0440\u0430  \u0437\u0430 \u043f\u0440\u0435\u043a\u0440\u0430\u0441\u043d\u0443\u044e \u0440\u0430\u0431\u043e\u0442\u0443 \u0438 \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u0438\u0435 \u0412\u041a\u041e\u041d\u0422\u0410\u041a\u0422\u0415.\n\n\n\n\n________________________________________________________________________________________________________\n\n\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2588\n\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2580\u2580\u2580\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2580\u2580\u2580\u2588\u2588\u2588\u2588\u2588\u2588\u2588\n\u2588\u2588\u2588\u2588\u2580\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2580\u2588\u2588\u2588\u2588 \n\u2588\u2588\u2588\u2502\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2502\u2588\u2588\u2588 \n\u2588\u2588\u258c\u2502\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2502\u2590\u2588\u2588 \n\u2588\u2588\u2591\u2514\u2510\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u2591\u250c\u2518\u2591\u2588\u2588 \n\u2588\u258