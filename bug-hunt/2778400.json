  "summaries": [
    {
      "id": 602084,
      "category": "team",
      "content": "We thank @andresbebe for the report and for providing clear reproduction steps with a proof-of-concept code demonstrating the vulnerability. MercadoLibre acknowledged the issue and worked on a fix internally.\n\nA vulnerability has been identified in the Point Smart application where users can navigate outside the intended application environment through a link. This navigation capability potentially allows for the vectorization of phishing attacks.",
      "updated_at": "2024-12-11T20:49:01.276Z",
      "can_view?": true,
      "can_create?": false,
